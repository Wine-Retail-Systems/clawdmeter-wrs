# Lokale Build-Konfiguration für die Companion-App.
# Kopiere zu `.env.local` und fülle die Werte aus. `.env.local` ist über
# companion/.gitignore (Pattern `*.local`) vom Versionsmanagement ausgeschlossen.
#
# Nutzung:
#   set -a; source .env.local; set +a && pnpm tauri build
# Oder bequemer via direnv (siehe `.envrc` im Repo-Root).

# ─── macOS Code-Signing (Developer ID Application) ──────────────────────
# Cert liegt im Keychain — lokal reicht der Identity-String. Tauri findet
# den privaten Schlüssel über die Keychain. Lookup:
#   security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="Developer ID Application: DEIN NAME (TEAMID)"
APPLE_TEAM_ID="TEAMID"

# Nur in CI gesetzt — das base64-codierte .p12 wird dort in eine temporäre
# Keychain importiert. Lokal NICHT setzen.
# APPLE_CERTIFICATE="<base64-of-developer-id.p12>"
# APPLE_CERTIFICATE_PASSWORD="<p12-passwort>"

# ─── macOS Notarization (App Store Connect API-Key) ─────────────────────
# Key erzeugen unter:
#   App Store Connect → Users and Access → Integrations →
#   App Store Connect API → "+" → Access: Developer
# Apple gibt die .p8-Datei einmalig aus — sicher ablegen.
APPLE_API_KEY="ABCD123456"
APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"
APPLE_API_KEY_PATH="/absoluter/pfad/AuthKey_ABCD123456.p8"

# ─── Tauri Updater (ED25519 Signing) ───────────────────────────────────
# Schlüsselpaar erzeugen:
#   pnpm tauri signer generate -w ~/.tauri/clawdmeter.key
# Pubkey landet in companion/src-tauri/tauri.conf.json (plugins.updater.pubkey).
# Privkey + Passwort bleiben lokal/in GitHub Secrets.
TAURI_SIGNING_PRIVATE_KEY="/absoluter/pfad/clawdmeter.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD="<key-passwort>"

# ─── Hinweise ──────────────────────────────────────────────────────────
# • Wenn `pnpm tauri build` mit "no identity found" abbricht, prüfe ob
#   `security find-identity -v -p codesigning` deinen Eintrag listet.
# • APPLE_CERTIFICATE / APPLE_CERTIFICATE_PASSWORD nur für CI.
# • Windows-Build vom Mac aus benötigt zusätzlich Rust + cargo-xwin + NSIS;
#   siehe feature-documentation/companion-app/local-build.md.
