# direnv-Hook für lokale Build-Variablen.
# Aktivierung einmalig:
#   brew install direnv && echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc
#   direnv allow
#
# .envrc IST eingecheckt (legt nur das Layout fest, keine Secrets).
# Die Secrets liegen in companion/.env.local — dort wird automatisch
# nachgeladen, sobald du ins Repo wechselst.

if [ -f companion/.env.local ]; then
    dotenv companion/.env.local
fi
